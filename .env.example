# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# EMAIL_USER: The email address to send contact form submissions from.
# EMAIL_PASS: The password or app password for the email account.
EMAIL_USER=
EMAIL_PASS=
# CONTACT_RECEIVER: The email address that will receive the contact form submissions.
CONTACT_RECEIVER=
